{
  "name": "@darkobits/eslint-config",
  "version": "4.0.0-beta.4",
  "description": "ESLint configuration presets for TypeScript projects.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/darkobits/eslint-plugin.git"
  },
  "license": "SEE LICENSE IN LICENSE",
  "author": "darkobits",
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch src",
    "lint": "eslint --cache",
