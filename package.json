{
  "name": "@darkobits/eslint-config",
  "version": "4.0.0-beta.2",
  "description": "ESLint configuration presets for TypeScript projects.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/darkobits/eslint-plugin.git"
  },
  "license": "Hippocratic",
  "type": "module",
  "author": "darkobits",
  "exports": {
    ".": "./dist/index.js",
    "./configs/ts": "./dist/configs/ts.js",
    "./configs/tsx": "./dist/configs/tsx.js",
    "./types": "./dist/types.js",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch src",
    "lint": "eslint --cache",
    "lint:fix": "eslint --cache --fix",
    "test": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "test:watch": "vitest",
    "tsc": "tsc",
    "tsc:watch": "tsc --watch",
    "release": "release-it",
    "release:dry": "release-it --dry-run",
    "release:beta": "release-it --preRelease=beta",
    "release:alpha": "release-it --preRelease=alpha",
    "release:rc": "release-it --preRelease=rc"
  },
  "dependencies": {
    "@eslint/js": "^9.33.0",
    "@stylistic/eslint-plugin": "^5.2.3",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-unicorn": "^59.0.1",
    "get-tsconfig": "^4.10.1",
    "typescript-eslint": "^8.39.1"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^10.0.1",
    "@types/eslint": "^9.6.1",
    "@types/node": "^22.17.1",
    "@types/react": "^19.1.10",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9.33.0",
    "eslint-plugin-package-json": "~0.52.1",
    "jiti": "^2.5.1",
    "publint": "^0.3.12",
    "react": "^19.1.1",
    "release-it": "^19.0.4",
    "ts-essentials": "^10.1.1",
    "tsdown": "~0.14.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.2",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "eslint": "^9.0.0"
  },
  "packageManager": "pnpm@10.14.0+sha512.ad27a79641b49c3e481a16a805baa71817a04bbe06a38d17e60e2eaee83f6a146c6a688125f5792e48dd5ba30e7da52a5cda4c3992b9ccf333f9ce223af84748",
  "engines": {
    "node": ">=22"
  }
}
