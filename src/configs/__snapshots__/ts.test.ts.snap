              "schema": [
                {
                  "additionalProperties": false,
                  "properties": {
                    "allow": {
                      "description": "Types to allow in template expressions.",
                      "items": {
                        "oneOf": [
                          {
                            "type": "string",
                          },
                          {
                            "additionalProperties": false,
