                            "amd": {
                              "type": "boolean",
                            },
                            "commonjs": {
                              "type": "boolean",
                            },
                            "esmodule": {
                              "type": "boolean",
                            },
                            "ignore": {
                              "items": {
                                "type": "string",
                              },
                              "minItems": 1,
                              "type": "array",
                              "uniqueItems": true,
                            },
                          },
                          "type": "object",
