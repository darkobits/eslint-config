                        "propElementValues": {
                          "enum": [
                            "always",
                            "never",
                            "ignore",
                          ],
                          "type": "string",
                        },
                        "props": {
                          "enum": [
                            "always",
                            "never",
                            "ignore",
                          ],
                          "type": "string",
                        },
                      },
                      "type": "object",
                    },
                    {
                      "enum": [
                        "always",
                        "never",
                        "ignore",
                      ],
                      "type": "string",
                    },
                  ],
                },
              ],
              "type": "layout",
            },
          },
          "jsx-curly-newline": {
            "create": [Function],
            "defaultOptions": [],
            "meta": {
              "docs": {
                "description": "Enforce consistent linebreaks in curly braces in JSX attributes and expressions",
                "url": "https://eslint.style/rules/jsx/jsx-curly-newline",
