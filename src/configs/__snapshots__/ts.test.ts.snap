                          "type": "string",
                        },
                      },
                      "type": "object",
                    },
                    {
                      "additionalProperties": false,
                      "properties": {
                        "nonEmpty": {
                          "oneOf": [
                            {
                              "enum": [
                                "after-props",
                                "props-aligned",
                                "tag-aligned",
                                "line-aligned",
                              ],
                              "type": "string",
                            },
                            {
                              "enum": [
                                false,
                              ],
                              "type": "boolean",
                            },
                          ],
                        },
                        "selfClosing": {
                          "oneOf": [
                            {
                              "enum": [
