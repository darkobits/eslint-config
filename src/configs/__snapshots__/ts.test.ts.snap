                      ],
                      "type": "problem",
                    },
                  },
                  "no-self-import": {
                    "create": [Function],
                    "meta": {
                      "docs": {
                        "category": "Static analysis",
                        "description": "Forbid a module from importing itself.",
                        "recommended": true,
                        "url": "https://github.com/import-js/eslint-plugin-import/blob/v2.32.0/docs/rules/no-self-import.md",
                      },
                      "schema": [],
