                            "sortTypesGroup": {
                              "oneOf": [
                                {
                                  "properties": {
                                    "groups": {
                                      "not": {
                                        "items": {
                                          "oneOf": [
                                            {
                                              "enum": [
                                                "builtin",
                                                "external",
                                                "internal",
                                                "unknown",
                                                "parent",
                                                "sibling",
                                                "index",
                                                "object",
                                              ],
                                            },
                                            {
                                              "items": {
                                                "enum": [
                                                  "builtin",
                                                  "external",
                                                  "internal",
                                                  "unknown",
                                                  "parent",
                                                  "sibling",
                                                  "index",
                                                  "object",
                                                ],
                                              },
                                              "type": "array",
                                              "uniqueItems": true,
                                            },
                                          ],
                                        },
                                        "type": "array",
                                        "uniqueItems": true,
                                      },
                                    },
                                    "sortTypesGroup": {
                                      "enum": [
                                        true,
                                      ],
                                    },
                                  },
                                  "required": [
                                    "groups",
                                  ],
                                },
                                {
                                  "properties": {
                                    "sortTypesGroup": {
                                      "enum": [
                                        false,
                                      ],
                                    },
                                  },
                                },
                              ],
                            },
                          },
                          "properties": {
                            "alphabetize": {
                              "additionalProperties": false,
                              "properties": {
                                "caseInsensitive": {
                                  "default": false,
                                  "type": "boolean",
                                },
                                "order": {
                                  "default": "ignore",
                                  "enum": [
                                    "ignore",
                                    "asc",
                                    "desc",
                                  ],
                                },
                                "orderImportKind": {
                                  "default": "ignore",
                                  "enum": [
                                    "ignore",
                                    "asc",
                                    "desc",
                                  ],
                                },
                              },
                              "type": "object",
                            },
                            "consolidateIslands": {
                              "enum": [
                                "inside-groups",
