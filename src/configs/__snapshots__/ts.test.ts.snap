                      "enum": [
                        "semi",
                        "comma",
                      ],
                      "type": "string",
                    },
                  },
                  "additionalProperties": false,
                  "properties": {
                    "multiline": {
                      "additionalProperties": false,
                      "properties": {
                        "delimiter": {
                          "$ref": "#/items/0/$defs/multiLineOption",
                        },
