                                        "internal",
                                        "unknown",
                                        "parent",
                                        "sibling",
                                        "index",
                                        "object",
                                        "type",
                                      ],
                                    },
                                    "type": "array",
                                    "uniqueItems": true,
                                  },
                                ],
                              },
                              "type": "array",
                              "uniqueItems": true,
                            },
                            "named": {
                              "default": false,
                              "oneOf": [
                                {
                                  "type": "boolean",
