          "prefer-nullish-coalescing": {
            "create": [Function],
            "defaultOptions": [
              {
                "allowRuleToRunWithoutStrictNullChecksIKnowWhatIAmDoing": false,
                "ignoreBooleanCoercion": false,
                "ignoreConditionalTests": true,
                "ignoreIfStatements": false,
                "ignoreMixedLogicalExpressions": false,
                "ignorePrimitives": {
                  "bigint": false,
                  "boolean": false,
                  "number": false,
                  "string": false,
