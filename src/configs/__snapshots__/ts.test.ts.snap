            "meta": {
              "deprecated": {
                "deprecatedSince": "6.0.0",
                "replacedBy": [
                  {
                    "rule": {
                      "name": "@typescript-eslint/consistent-type-definitions",
                      "url": "https://typescript-eslint.io/rules/consistent-type-definitions",
