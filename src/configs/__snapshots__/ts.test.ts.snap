                                        "type": "array",
                                        "uniqueItems": true,
                                      },
                                    ],
                                  },
                                  "message": {
                                    "type": "string",
                                  },
                                  "target": {
                                    "anyOf": [
                                      {
                                        "type": "string",
                                      },
                                      {
                                        "items": {
                                          "type": "string",
                                        },
                                        "minLength": 1,
                                        "type": "array",
                                        "uniqueItems": true,
                                      },
                                    ],
