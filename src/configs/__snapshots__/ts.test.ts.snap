                                },
                                {
                                  "enum": [
                                    "first",
                                    "off",
                                  ],
                                  "type": "string",
                                },
                              ],
                            },
                            "var": {
                              "oneOf": [
                                {
                                  "minimum": 0,
                                  "type": "integer",
                                },
                                {
                                  "enum": [
                                    "first",
                                    "off",
                                  ],
                                  "type": "string",
                                },
                              ],
                            },
                          },
                          "type": "object",
                        },
                      ],
                    },
                    "flatTernaryExpressions": {
                      "default": false,
                      "type": "boolean",
                    },
                    "ignoreComments": {
                      "default": false,
                      "type": "boolean",
                    },
                    "ignoredNodes": {
                      "items": {
                        "not": {
                          "pattern": ":exit$",
                        },
                        "type": "string",
                      },
                      "type": "array",
                    },
                    "offsetTernaryExpressions": {
                      "default": false,
                      "type": "boolean",
                    },
                    "offsetTernaryExpressionsOffsetCallExpressions": {
                      "default": true,
                      "type": "boolean",
                    },
                    "outerIIFEBody": {
                      "oneOf": [
                        {
                          "minimum": 0,
                          "type": "integer",
                        },
                        {
                          "enum": [
                            "off",
                          ],
                          "type": "string",
                        },
                      ],
                    },
                    "tabLength": {
                      "default": 4,
                      "type": "number",
                    },
                  },
                  "type": "object",
                },
              ],
              "type": "layout",
            },
          },
          "indent-binary-ops": {
            "create": [Function],
            "defaultOptions": [
              2,
