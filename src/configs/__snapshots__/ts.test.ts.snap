                        "url": "https://github.com/import-js/eslint-plugin-import/blob/v2.32.0/docs/rules/no-unresolved.md",
                      },
                      "schema": [
                        {
                          "additionalProperties": false,
                          "properties": {
                            "amd": {
                              "type": "boolean",
                            },
                            "caseSensitive": {
                              "default": true,
                              "type": "boolean",
                            },
                            "caseSensitiveStrict": {
                              "default": false,
                              "type": "boolean",
                            },
                            "commonjs": {
                              "type": "boolean",
                            },
                            "esmodule": {
                              "type": "boolean",
