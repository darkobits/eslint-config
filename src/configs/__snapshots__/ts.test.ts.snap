          "no-empty-interface": {
            "create": [Function],
            "defaultOptions": [
              {
                "allowSingleExtends": false,
              },
            ],
            "meta": {
              "deprecated": {
                "deprecatedSince": "8.0.0",
                "replacedBy": [
                  {
                    "rule": {
                      "name": "@typescript-eslint/no-empty-object-type",
                      "url": "https://typescript-eslint.io/rules/no-empty-object-type",
